# Copy to .env.local and fill values. Do NOT commit secrets.

# Public (browser) keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side (optional for server helpers)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Service role key: only set as protected env var in Vercel (do NOT commit)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Other envs used by the app
# DATA_MODE=supabase
# local = dados em data/store.json (padrão se Supabase não estiver configurado)
# supabase = Auth + PostgreSQL no Supabase
DATA_MODE=local

# Só necessário com DATA_MODE=supabase:
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon
