# Copy to .env.local and fill values. Do NOT commit secrets.

# App data mode
# mock = local JSON database in data/store.json, no Supabase
# production = Supabase Auth + PostgreSQL
DATA_MODE=mock

# Required only with DATA_MODE=production
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side optional aliases
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Service role key: only set as protected env var in Vercel. Do NOT commit it.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
